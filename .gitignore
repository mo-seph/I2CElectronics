.vscode/c_cpp_properties.json
.vscode/launch.json
.vscode/ipch

# macOS folder metadata
.DS_Store

# pioarduino / IDF component manager (generated, not needed for espressif32 platform)
src/idf_component.yml
src/idf_component.yml.orig
managed_components/

# Local scratch — serial logs, pid files, etc.
.tmp/
